{
  "name": "team-task-manager",
  "version": "1.0.0",
  "description": "Full-Stack Team Task Manager",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run start --workspace=backend\" \"npm run dev --workspace=frontend\"",
    "build": "npm run build --workspace=frontend",
    "start": "node backend/server.js"
  },
  "dependencies": {
    "concurrently": "^8.2.2"
  }
}
