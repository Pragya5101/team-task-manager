# Backend Configuration Template

# Port the backend server will listen on
PORT=5000

# Connection string for your hosted/remote database (PostgreSQL)
# e.g., Supabase: postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres
# e.g., Neon: postgresql://[USER]:[PASSWORD]@ep-[HOST].us-east-2.aws.neon.tech/neondb?sslmode=require
# If left blank, the server will fallback to a local SQLite database (database.sqlite)
DATABASE_URL=

# Secret key used to sign and verify JSON Web Tokens (JWT) for authentication
JWT_SECRET=some_extremely_long_and_secure_random_secret_key_change_me_in_production
